# Custom fastfetch
alias axfetch 'clear && fastfetch'
alias kittyfetch 'clear && fastfetch'
alias sansfetch 'clear && fastfetch'
alias adrienfetch 'clear && fastfetch'
alias anifetch 'kitty +kitten icat -n --place 100x8@0x0 --align left ~/.adrien.gif | fastfetch -c minimal --logo-width 25 --raw -'

# Cava gradient support for Tmux
alias cavax 'TERM=st-256color cava'
